# Copy to .env and adjust. .env is gitignored and excluded from Docker images.

# Which config class to load: development | testing | production
APP_ENV=development

# Flask's debug mode is a boolean: 1 or 0. Never set this to 1 in production:
# the Werkzeug debugger exposes an interactive console to anyone who can
# trigger a traceback.
FLASK_DEBUG=1
FLASK_APP=run.py

# Required in production, where the app refuses to start without it. Left empty
# here so development generates an ephemeral one per restart.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Logging: DEBUG|INFO|WARNING|ERROR and plain|json
LOG_LEVEL=INFO
LOG_FORMAT=plain

# Number of reverse-proxy hops to trust for X-Forwarded-* headers. Keep at 0
# unless the app really is behind a proxy -- otherwise clients can spoof their
# own source IP and scheme.
TRUST_PROXY_HOPS=0
